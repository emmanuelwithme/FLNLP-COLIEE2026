# modernBert-fp-chunkAgg local configuration
# 中文註解：本檔會被 fine_tune.py / inference.py / similarity_and_rank.py 自動讀取。
# 中文註解：若同名環境變數已在 shell 內存在，程式會優先使用 shell 內的值，不會被本檔覆蓋。

# ========================
# 核心 chunk encoder 設定
# ========================
# 中文註解：每篇文件最多切成幾個 chunk。
TASK1_MAX_DOCUMENT_CHUNKS=3
# 中文註解：每個 chunk 的 token 上限，含 special tokens。
TASK1_DOCUMENT_CHUNK_LENGTH=4096
# 中文註解：encoder 每次前向最多送幾個 chunk，4080 SUPER 可先試 2；若 OOM 再降回 1。
TASK1_CHUNK_MICROBATCH_SIZE=2
# 中文註解：1=啟用 TF32，加速 Ampere/Ada GPU 的 matmul；若要最嚴格可重現可改成 0。
TASK1_CHUNKAGG_ENABLE_TF32=1
# 中文註解：資料集層文字快取數量，減少重複讀檔。
TASK1_CHUNKAGG_TEXT_CACHE_SIZE=4096
# 中文註解：collator 層 chunk tokenization 快取數量，減少重複 tokenizer 開銷。
TASK1_CHUNKAGG_CHUNK_CACHE_SIZE=1024
# 中文註解：dataloader 傳輸加速設定；一般建議保持 1。
TASK1_CHUNKAGG_PIN_MEMORY=1
TASK1_CHUNKAGG_PERSISTENT_WORKERS=1
# 中文註解：對比式學習初始溫度。
TASK1_INIT_TEMPERATURE=0.2222
# 中文註解：retrieval / adaptive negative sampling / inference 的文件編碼 batch size。
TASK1_RETRIEVAL_BATCH_SIZE=8

# ========================
# 訓練設定
# ========================
# 中文註解：1=只跑極少量資料做 smoke test，0=正式訓練。
TASK1_CHUNKAGG_QUICK_TEST=0
# 中文註解：1=依 query 年份限制 candidates，0=對全部 candidates 檢索。
TASK1_CHUNKAGG_SCOPE_FILTER=1
# 中文註解：QUICK_TEST 模式下最多抽多少 candidate / query。
TASK1_CHUNKAGG_QT_CAND_K=20
TASK1_CHUNKAGG_QT_QUERY_K=5
# 中文註解：訓練 batch 與 gradient accumulation。
TASK1_CHUNKAGG_TRAIN_BATCH_SIZE=1
TASK1_CHUNKAGG_GRAD_ACCUM_STEPS=4
TASK1_CHUNKAGG_EVAL_BATCH_SIZE=1
# 中文註解：訓練 epoch 與 optimizer 超參數。
TASK1_CHUNKAGG_NUM_EPOCHS=20
TASK1_CHUNKAGG_ENCODER_LR=5e-6
TASK1_CHUNKAGG_FUSION_LR=5e-5
# TASK1_CHUNKAGG_TEMPERATURE如果太大可以從5e-4調整到5e-5
TASK1_CHUNKAGG_TEMPERATURE_LR=5e-4
TASK1_CHUNKAGG_WARMUP_RATIO=0.1
TASK1_CHUNKAGG_NUM_WORKERS=8
TASK1_CHUNKAGG_SAVE_TOTAL_LIMIT=20
# 中文註解：adaptive negative sampling 的抽樣溫度與更新頻率。
TASK1_CHUNKAGG_SAMPLING_TEMPERATURE=1.0
TASK1_CHUNKAGG_UPDATE_FREQUENCY=1

# ========================
# 推論 / 輸出命名
# ========================
# 中文註解：inference.py 與 similarity_and_rank.py 會共用這個模型名稱來決定 embeddings / ranking 檔名。
TASK1_CHUNKAGG_MODEL_NAME=modernBert_fp_chunkAgg_fp16
# 中文註解：1=推論只編碼少量文件，0=正式產生全部 embeddings。
TASK1_CHUNKAGG_INFER_QUICK_TEST=0
# 中文註解：推論時是否預設找 scopeFilteredRaw 的訓練輸出目錄。
TASK1_CHUNKAGG_INFER_SCOPE_FILTER=1
# 中文註解：推論 QUICK_TEST 最多編碼多少篇文件。
TASK1_CHUNKAGG_INFER_QT_LIMIT=20

# ========================
# 路徑覆寫（需要時再打開）
# ========================
# 中文註解：若不設定，程式會使用 repo 內建的預設 backbone checkpoint。
# TASK1_CHUNKAGG_BASE_ENCODER_DIR=/abs/path/to/modernbert-caselaw-accsteps-fp/checkpoint-29000
# 中文註解：若不設定，train 會自動根據 QUICK_TEST / SCOPE_FILTER / TASK1_YEAR 組合輸出路徑。
# TASK1_CHUNKAGG_OUTPUT_DIR=./modernBERT_contrastive_adaptive_fp_fp16_chunkAgg_scopeFilteredRaw_2023
# 中文註解：存 adaptive negatives 與 retrieval artifacts 的資料夾。
# TASK1_CHUNKAGG_FINETUNE_DATA_DIR=/abs/path/to/finetune_data
# 中文註解：inference.py 的輸入文件資料夾。
# TASK1_CHUNKAGG_CANDIDATE_DIR=/abs/path/to/processed
# TASK1_CHUNKAGG_QUERY_DIR=/abs/path/to/processed_new
# 中文註解：inference.py 輸出的 embeddings 檔案。
# 中文註解：similarity_and_rank.py 預設 query / candidate 都使用 processed；可用 *_EMB_SOURCE 切換。
# TASK1_CHUNKAGG_CAND_EMB_SOURCE=processed
# TASK1_CHUNKAGG_QUERY_EMB_SOURCE=processed
# TASK1_CHUNKAGG_CAND_EMB_PATH=/abs/path/to/processed_document_modernBert_fp_chunkAgg_fp16_embeddings.pkl
# TASK1_CHUNKAGG_QUERY_EMB_PATH=/abs/path/to/processed_new_document_modernBert_fp_chunkAgg_fp16_embeddings.pkl
# 中文註解：similarity_and_rank.py 的 query id 與輸出排名檔路徑。
# TASK1_CHUNKAGG_VALID_QID_PATH=/abs/path/to/valid_qid.tsv
# TASK1_CHUNKAGG_TRAIN_QID_PATH=/abs/path/to/train_qid.tsv
# TASK1_CHUNKAGG_SCOPE_PATH=/abs/path/to/query_candidate_scope.json
# TASK1_CHUNKAGG_OUTPUT_DOT_TRAIN=/abs/path/to/output_dot_train.tsv
# TASK1_CHUNKAGG_OUTPUT_DOT_VALID=/abs/path/to/output_dot_valid.tsv
# TASK1_CHUNKAGG_OUTPUT_COS_TRAIN=/abs/path/to/output_cos_train.tsv
# TASK1_CHUNKAGG_OUTPUT_COS_VALID=/abs/path/to/output_cos_valid.tsv
